# Wazuh Deployer - Environment Configuration
# Copy this file to .env and modify values according to your environment

# Deployment Mode
DEPLOYMENT_MODE=full  # Options: full, partial, dry-run
DRY_RUN=false

# Wazuh Version
WAZUH_VERSION=4.14.0

# Architecture
ARCHITECTURE=distributed  # Options: all-in-one, distributed

# Component Configuration
WAZUH_MANAGER_HOST=localhost
WAZUH_INDEXER_HOST=localhost
WAZUH_DASHBOARD_HOST=localhost
WAZUH_MANAGER_PORT=15150
WAZUH_INDEXER_PORT=9200
WAZUH_DASHBOARD_PORT=443

# TLS Configuration
ENABLE_TLS=true
TLS_CERT_PATH=/etc/wazuh/certs/
TLS_KEY_PATH=/etc/wazuh/certs/
TLS_CA_PATH=/etc/wazuh/certs/

# Authentication
WAZUH_API_USER=admin
WAZUH_API_PASSWORD=change_me
INDEXER_USER=admin
INDEXER_PASSWORD=change_me

# Agent Configuration
DEFAULT_AGENT_GROUP=default
ENABLE_ANTI_TAMPERING=false

# Database/Storage
DATA_RETENTION_DAYS=90
ARCHIVE_RETENTION_DAYS=30
ENABLE_ARCHIVES=false

# Dashboard Configuration
ENABLE_DASHBOARD=true
DASHBOARD_SSL=true

# Integrations
ENABLE_DOCKER_INTEGRATION=false
ENABLE_AWS_INTEGRATION=false
ENABLE_GCP_INTEGRATION=false
ENABLE_GITHUB_INTEGRATION=false
ENABLE_OFFICE365_INTEGRATION=false
ENABLE_MS_GRAPH_INTEGRATION=false

# AWS Configuration (if enabled)
AWS_S3_BUCKET=
AWS_REGION=
AWS_PROFILE=default

# GCP Configuration (if enabled)
GCP_PROJECT_ID=
GCP_SUBSCRIPTION_NAME=
GCP_CREDENTIALS_FILE=

# GitHub Configuration (if enabled)
GITHUB_ORG_NAME=
GITHUB_API_TOKEN=

# Office 365 Configuration (if enabled)
O365_TENANT_ID=
O365_CLIENT_ID=
O365_CLIENT_SECRET=

# Microsoft Graph Configuration (if enabled)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_SECRET_VALUE=

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/wazuh_deployer.log

# Backup
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# Notifications
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# Slack/Teams Notification
ENABLE_SLACK_NOTIFICATION=false
SLACK_WEBHOOK_URL=

# Production Checklist
ENABLE_PRODUCTION_CHECKLIST=true
REQUIRE_CONFIRMATION=true
