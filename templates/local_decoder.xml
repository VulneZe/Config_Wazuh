<!-- Local Decoders -->
<!-- Custom decoders for Obeo environment -->
<!-- Generated by Wazuh Deployer -->

<!-- Example decoder for custom application logs -->
<decoder name="custom-app">
  <program_name>^custom-app</program_name>
</decoder>

<decoder name="custom-app-login">
  <parent>custom-app</parent>
  <regex>User '(\w+)' logged from '(\d+.\d+.\d+.\d+)'</regex>
  <order>user, srcip</order>
</decoder>

<!-- Example decoder for web application logs -->
<decoder name="web-app">
  <program_name>^web-app</program_name>
</decoder>

<decoder name="web-app-error">
  <parent>web-app</parent>
  <regex>\[ERROR\] (\w+) - (.+)</regex>
  <order>module, message</order>
</decoder>

<!-- Example decoder for custom security logs -->
<decoder name="security-log">
  <prematch>^\[SECURITY\]</prematch>
</decoder>

<decoder name="security-log-auth">
  <parent>security-log</parent>
  <regex>\[SECURITY\] AUTH (\w+) (\S+) from (\S+)</regex>
  <order>action, user, srcip</order>
</decoder>
