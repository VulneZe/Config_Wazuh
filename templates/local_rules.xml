<group name="obeo_custom,">
  
  <!-- Example: Custom rule for backup-bot SSH connections -->
  <rule id="100001" level="0">
    <program_name>sshd</program_name>
    <match>Accepted publickey for backup-bot</match>
    <field name="agent.name">^srv-bastion-01$</field>
    <description>Expected SSH connection from backup-bot account on bastion</description>
  </rule>
  
  <!-- Example: Custom rule for Ansible automation -->
  <rule id="100002" level="0">
    <program_name>sshd</program_name>
    <match>Accepted publickey for ansible</match>
    <description>Expected SSH connection from Ansible automation account</description>
  </rule>
  
  <!-- Example: Override SSH brute force detection level -->
  <rule id="5710" level="10" overwrite="yes">
    <if_sid>5700</if_sid>
    <match>illegal user|invalid user</match>
    <description>sshd: Attempt to login using a non-existent user</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,gdpr_IV_32.2</group>
  </rule>
  
  <!-- Example: Sensitive file modification on tier1 systems -->
  <rule id="100003" level="12">
    <if_sid>550</if_sid>
    <field name="file">/etc/passwd|/etc/shadow|/etc/sudoers|/etc/ssh/sshd_config</field>
    <description>Sensitive system file modified on tier1 system</description>
    <group>syscheck,pci_dss_10.2.7,gdpr_IV_32.2</group>
  </rule>
  
  <!-- Example: Docker container with privileged mode -->
  <rule id="100004" level="10">
    <if_sid>100000</if_sid>
    <match>Privileged:true</match>
    <description>Docker container started with privileged mode</description>
    <group>docker,security</group>
  </rule>
  
  <!-- Example: GitHub admin action -->
  <rule id="100005" level="8">
    <if_sid>100200</if_sid>
    <match>admin</match>
    <description>GitHub administrative action detected</description>
    <group>github,security</group>
  </rule>
  
  <!-- Example: Office 365 admin action -->
  <rule id="100006" level="10">
    <if_sid>100300</if_sid>
    <match>admin</match>
    <description>Office 365 administrative action detected</description>
    <group>office365,security,gdpr_IV_32.2</group>
  </rule>
  
  <!-- Example: XEN hypervisor modification -->
  <rule id="100007" level="12">
    <if_sid>550</if_sid>
    <field name="file">/etc/xen</field>
    <description>XEN hypervisor configuration modified</description>
    <group>syscheck,hypervisor,security</group>
  </rule>
  
  <!-- Example: New systemd service created -->
  <rule id="100008" level="8">
    <if_sid>510</if_sid>
    <match>Created symlink</match>
    <match>systemd/system</match>
    <description>New systemd service created</description>
    <group>systemd,persistence</group>
  </rule>
  
</group>
